# QuantDinger 本地配置（复制为 `.env` 后再编辑）
# 若存在 `backend_api_python/.env`，`run.py` 会自动加载。
#
# 本文件结构如下：
# 1) 顶部是首次部署常用配置
# 2) 底部是高级/较少改动的配置
# Docker 镜像源与端口请使用项目根目录的 `.env`。

# =========================
# 认证（必填）
# =========================
# 同时用于派生 Fernet 密钥，给 qd_exchange_credentials.encrypted_config 加密（不要随意轮换）。
SECRET_KEY=quantdinger-secret-key-change-me
ADMIN_USER=quantdinger
ADMIN_PASSWORD=123456
ADMIN_EMAIL=

# =========================
# 核心应用
# =========================
DATABASE_URL=postgresql://quantdinger:quantdinger123@postgres:5432/quantdinger
FRONTEND_URL=http://localhost:8888
ENABLE_REGISTRATION=true

# =========================
# 数据库连接池（psycopg2 ThreadedConnectionPool）
# =========================
# 如果出现 `psycopg2.pool.PoolError: connection pool exhausted`
# 或者并发运行了较多交易机器人/投资组合，可调优这些参数。
# 请确保 PG `max_connections`（docker-compose: PG_MAX_CONNECTIONS）
# 明显大于 DB_POOL_MAX。
DB_POOL_MIN=5
DB_POOL_MAX=50
DB_POOL_ACQUIRE_TIMEOUT=10
DB_POOL_HEALTH_CHECK=true

# 路由级并行抓取执行器。每个 worker 可能占用一个数据库连接，
# 因此请让 MARKET_EXECUTOR_WORKERS + PORTFOLIO_EXECUTOR_WORKERS
# 明显低于 DB_POOL_MAX。
MARKET_EXECUTOR_WORKERS=6
PORTFOLIO_EXECUTOR_WORKERS=3

# Gunicorn worker/线程模型
GUNICORN_WORKERS=1
GUNICORN_THREADS=8

# =========================
# AI / LLM（选择一个提供商）
# =========================
LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
# 可选：AI 代码生成专用模型（留空则回退到提供商默认模型）
AI_CODE_GEN_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

GROK_API_KEY=
GROK_MODEL=grok-beta

# =========================
# 通用后台任务
# =========================
ENABLE_PENDING_ORDER_WORKER=true
ENABLE_PORTFOLIO_MONITOR=true
DISABLE_RESTORE_RUNNING_STRATEGIES=false

# =========================
# 邮件 / SMTP（可选）
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# =========================
# 代理（可选）
# =========================
# PROXY_URL=socks5h://127.0.0.1:10808         # 本地
# PROXY_URL=socks5h://host.docker.internal:10808  # Docker
PROXY_URL=

# 使用 PROXY_URL（尤其是 SOCKS）访问交易所 HTTPS 出站请求时，如果出现
# SSLCertVerificationError / "unable to get local issuer certificate"：
# - 优先方案：在镜像中安装操作系统 ca-certificates，或指定 PEM 证书包：
#   LIVE_TRADING_CA_BUNDLE=/path/to/ca-bundle.pem
#   （也支持 REQUESTS_CA_BUNDLE / SSL_CERT_FILE。）
# - 最后手段：LIVE_TRADING_SSL_VERIFY=false  # 关闭 TLS 校验（不安全）
#LIVE_TRADING_CA_BUNDLE=
#LIVE_TRADING_SSL_VERIFY=

# =========================
# 验证码 / OAuth（可选）
# =========================
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/oauth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5000/api/auth/oauth/github/callback

# =========================
# 计费 / 支付
# =========================
BILLING_ENABLED=false

# 积分单价
BILLING_COST_AI_ANALYSIS=10
BILLING_COST_AI_CODE_GEN=30

CREDITS_REGISTER_BONUS=100
CREDITS_REFERRAL_BONUS=50

# 会员套餐
MEMBERSHIP_MONTHLY_PRICE_USD=19.9
MEMBERSHIP_YEARLY_PRICE_USD=199
MEMBERSHIP_LIFETIME_PRICE_USD=499
MEMBERSHIP_MONTHLY_CREDITS=500
MEMBERSHIP_YEARLY_CREDITS=8000
MEMBERSHIP_LIFETIME_MONTHLY_CREDITS=800

# USDT 支付
USDT_PAY_ENABLED=false
USDT_PAY_CHAIN=TRC20
USDT_TRC20_XPUB=
USDT_TRC20_CONTRACT=TXLAQ63Xg1NAzckPwKHvzw7CSEmLMEqcdj
TRONGRID_BASE_URL=https://api.trongrid.io
TRONGRID_API_KEY=
USDT_PAY_CONFIRM_SECONDS=30
USDT_PAY_EXPIRE_MINUTES=30
USDT_WORKER_POLL_INTERVAL=30

# =========================
# 高级配置 / 较少改动
# =========================

# 网络 / 应用调优
PYTHON_API_HOST=0.0.0.0
PYTHON_API_PORT=5000
PYTHON_API_DEBUG=false
RATE_LIMIT=100
ENABLE_CACHE=false
ENABLE_REQUEST_LOG=true

# 策略 / 执行调优
PENDING_ORDER_STALE_SEC=90
ORDER_MODE=market
MAKER_WAIT_SEC=10
MAKER_OFFSET_BPS=2
STRATEGY_TICK_INTERVAL_SEC=10
PRICE_CACHE_TTL_SEC=10
K_LINE_HISTORY_GET_NUMBER=500
SIGNAL_NOTIFY_TIMEOUT_SEC=6

# LLM 高级调优
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=4000
OPENROUTER_TIMEOUT=300
OPENROUTER_CONNECT_TIMEOUT=30
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GROK_BASE_URL=https://api.x.ai/v1

# 数据源
DATA_SOURCE_TIMEOUT=30
DATA_SOURCE_RETRY=3
DATA_SOURCE_RETRY_BACKOFF=0.5
FINNHUB_API_KEY=
FINNHUB_TIMEOUT=10
FINNHUB_RATE_LIMIT=60
CCXT_DEFAULT_EXCHANGE=coinbase
CCXT_TIMEOUT=10000
AKSHARE_TIMEOUT=30
YFINANCE_TIMEOUT=30
TIINGO_API_KEY=
TIINGO_TIMEOUT=10

# Twelve Data（中国/港股 K 线，推荐海外服务器使用）
# 免费额度：800 API 积分/天，8 次请求/分钟。https://twelvedata.com
TWELVE_DATA_API_KEY=

# AI 搜索 / 新闻
SEARCH_PROVIDER=google
SEARCH_MAX_RESULTS=10
SEARCH_GOOGLE_API_KEY=
SEARCH_GOOGLE_CX=
SEARCH_BING_API_KEY=
TAVILY_API_KEYS=
SERPAPI_KEYS=

# 短信 / 手机（可选）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# 安全 / 验证调优
SECURITY_IP_MAX_ATTEMPTS=10
SECURITY_IP_WINDOW_MINUTES=5
SECURITY_IP_BLOCK_MINUTES=15
SECURITY_ACCOUNT_MAX_ATTEMPTS=5
SECURITY_ACCOUNT_WINDOW_MINUTES=60
SECURITY_ACCOUNT_BLOCK_MINUTES=30
VERIFICATION_CODE_EXPIRE_MINUTES=10
VERIFICATION_CODE_RATE_LIMIT=60
VERIFICATION_CODE_IP_HOURLY_LIMIT=10
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_LOCK_MINUTES=30

# AI 分析调优
ENABLE_CONFIDENCE_CALIBRATION=false
ENABLE_AI_ENSEMBLE=false
AI_ENSEMBLE_MODELS=openai/gpt-4o,openai/gpt-4o-mini
ENABLE_REFLECTION_WORKER=false
REFLECTION_WORKER_INTERVAL_SEC=86400
REFLECTION_MIN_AGE_DAYS=7
REFLECTION_VALIDATE_LIMIT=200
AI_CALIBRATION_MARKETS=Crypto
AI_CALIBRATION_LOOKBACK_DAYS=30
AI_CALIBRATION_MIN_SAMPLES=80
AI_ANALYSIS_CONSENSUS_TIMEFRAMES=1D,4H

# Redis 缓存（由 docker-compose 自动配置；设置 CACHE_ENABLED=true 启用）
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_ENABLED=true

# 内部配置
INTERNAL_API_KEY=
